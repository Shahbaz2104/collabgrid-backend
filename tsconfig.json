{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    
    // ADD THIS LINE INSIDE compilerOptions 👇
    "types": ["jest", "node"]
  },
  "include": ["src/**/*"]
}