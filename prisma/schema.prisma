datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // <-- THIS LINE WAS MISSING!
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("Member")
  createdAt DateTime @default(now())
}